MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=video-synopsis-audio

# Business Logic
MAX_VIDEO_DURATION_MINUTES=180
